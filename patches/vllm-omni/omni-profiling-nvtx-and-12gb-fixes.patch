+++ b/vllm_omni/engine/stage_engine_core_proc.py
@@ -47,12 +47,55 @@ logger = init_logger(__name__)
 
 _SIGNAL_EXIT_BASE = 128
 
+# Opt-in NVTX phase annotation. When set to a truthy value, every engine-core
+# step in this stage worker is wrapped in an NVTX range tagged with the logical
+# omni stage id (e.g. ``omni_stage0.step``). Because each stage runs in its own
+# process and pushes work onto its own CUDA stream, these ranges make it obvious
+# in an Nsight Systems timeline which stage a given burst of kernels belongs to
+# -- i.e. when the talker stage (0) and code2wav stage (1) actually overlap.
+_NVTX_ENV = "VLLM_OMNI_NVTX_STAGES"
+
 
 def _signal_exit_code(signum: int) -> int:
     """Return the conventional process exit code for signal-driven exits."""
     return _SIGNAL_EXIT_BASE + signum
 
 
+def _install_stage_nvtx(engine_core: "StageEngineCoreProc", omni_stage_id: int | None) -> None:
+    """Wrap ``engine_core.step_fn`` so each step emits a stage-tagged NVTX range.
+
+    No-op unless ``VLLM_OMNI_NVTX_STAGES`` is truthy. The busy loop reads
+    ``self.step_fn`` on every iteration, so replacing the attribute here is
+    sufficient and avoids matching the (version-specific) ``step`` signatures.
+    """
+    if os.environ.get(_NVTX_ENV, "").strip().lower() in ("", "0", "false", "no"):
+        return
+    try:
+        import torch
+    except Exception:  # pragma: no cover - torch should always be importable here
+        logger.warning("%s set but torch import failed; skipping NVTX wrap", _NVTX_ENV)
+        return
+
+    original_step_fn = getattr(engine_core, "step_fn", None)
+    if original_step_fn is None:
+        logger.warning("step_fn missing on engine core; skipping NVTX wrap")
+        return
+
+    stage_tag = f"omni_stage{omni_stage_id}" if omni_stage_id is not None else "omni_stage"
+    range_name = f"{stage_tag}.step"
+    nvtx = torch.cuda.nvtx
+
+    def _nvtx_step_fn(*args: Any, **kwargs: Any):
+        nvtx.range_push(range_name)
+        try:
+            return original_step_fn(*args, **kwargs)
+        finally:
+            nvtx.range_pop()
+
+    engine_core.step_fn = _nvtx_step_fn
+    logger.info("NVTX stage annotation enabled: ranges tagged '%s'", range_name)
+
+
 class StageEngineCoreProc(EngineCoreProc):
     """Stage-specific engine core process for vLLM-Omni.
 
